# Copy this file to .env and fill in real values to use the live Shopmetrics API.
# .env is gitignored and auto-loaded by src/config.py; never commit real secrets.
#
# Most non-secret settings (DB_BACKEND, EXTRACTION_MODE, COMMAND_MODE,
# SQLSERVER_SERVER, etc.) now live in config/config.json instead -- edit that
# file for everyday changes. Anything you set here overrides config.json.

# --- Secrets (required for EXTRACTION_MODE=api / COMMAND_MODE=live) ---
SHOPMETRICS_CLIENT_ID=
SHOPMETRICS_CLIENT_SECRET=

# --- Only set these if you need SQL Server authentication instead of
# Windows Authentication (DB_BACKEND=sqlserver) ---
# SQLSERVER_USER=
# SQLSERVER_PASSWORD=

# --- Optional overrides (uncomment to override config/config.json) ---
# SHOPMETRICS_BASE_URL=https://training212.shopmetrics.com
# SHOPMETRICS_CLIENT_OR_FORM_IDS=-995
# EXTRACTION_MODE=file
# COMMAND_MODE=mock
# DB_BACKEND=sqlite
# SQLSERVER_SERVER=.\SQLEXPRESS
# SQLSERVER_DATABASE=ShopmetricsETL
